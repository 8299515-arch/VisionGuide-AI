# VisionGuide AI - Environment Variables

# API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/visionguide

# Redis
REDIS_URL=redis://localhost:6379

# AI Models
YOLO_MODEL_PATH=yolov8n.pt
OCR_LANGS=en

# TTS
TTS_ENABLED=true
TTS_ENGINE=pyttsx3

# Security
SECRET_KEY=change_me

# Logging
LOG_LEVEL=info
